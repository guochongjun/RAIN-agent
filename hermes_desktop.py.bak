#!/usr/bin/env python3
"""
RAIN Desktop — Windows AI Assistant
Integrates the RAIN agent engine with PyQt5 GUI.
"""
import sys
import os
import io
import traceback
import datetime
from pathlib import Path

# ── Crash logger (catches everything, writes to Desktop) ────
_CRASH_LOG = Path(os.environ.get("USERPROFILE", ".")) / "Desktop" / "rain_crash.log"

def _log_crash(msg):
    try:
        with open(_CRASH_LOG, "a", encoding="utf-8") as f:
            f.write(f"[{datetime.datetime.now()}] {msg}\n")
    except Exception:
        pass

# Fix: windowed PyInstaller has no console → stdout/stderr are None
if sys.stdout is None:
    sys.stdout = io.StringIO()
if sys.stderr is None:
    sys.stderr = io.StringIO()

def _global_excepthook(exc_type, exc_val, exc_tb):
    tb_text = "".join(traceback.format_exception(exc_type, exc_val, exc_tb))
    _log_crash(f"UNHANDLED: {tb_text}")
    # Also show message box if Qt is available
    try:
        from PyQt5.QtWidgets import QApplication, QMessageBox
        if QApplication.instance():
            QMessageBox.critical(None, "RAIN - 崩溃", f"程序遇到错误:\n\n{str(exc_val)}\n\n详情已写入:\n{_CRASH_LOG}")
    except Exception:
        pass
    sys.__excepthook__(exc_type, exc_val, exc_tb)

sys.excepthook = _global_excepthook

